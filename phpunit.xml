<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <!-- Invoked explicitly by `make smoke` against a live target
             URL. Also filtered by the <groups><exclude> below so a
             forgotten SMOKE_TARGET_URL never red-lights the default
             `make test` run. -->
        <testsuite name="Smoke">
            <directory>tests/Smoke</directory>
        </testsuite>
    </testsuites>
    <groups>
        <exclude>
            <group>smoke</group>
        </exclude>
    </groups>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="HASH_DRIVER" value="argon2id"/>
        <!-- Minimum argon2id cost so the suite is not dominated by hash time.
             Prod hashes (m=65536, t=4) still verify fine because password_verify
             reads the cost out of the hash string, not from runtime config. -->
        <env name="ARGON_MEMORY" value="1024"/>
        <env name="ARGON_TIME" value="1"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="test-mysql"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_DATABASE" value="laravel"/>
        <env name="DB_USERNAME" value="root"/>
        <env name="DB_PASSWORD" value="secret"/>
        <env name="REDIS_HOST" value="test-redis"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
