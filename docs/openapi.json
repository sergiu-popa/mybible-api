{
    "openapi": "3.1.0",
    "info": {
        "title": "MyBible API",
        "version": "0.0.1"
    },
    "servers": [
        {
            "url": "http://mybible-api.localhost/api/v1"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "operationId": "auth.login",
                "tags": [
                    "Login"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginUserRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "user": {
                                                    "$ref": "#/components/schemas/UserResource"
                                                },
                                                "token": {
                                                    "type": "string"
                                                }
                                            },
                                            "required": [
                                                "user",
                                                "token"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "operationId": "auth.logout",
                "tags": [
                    "Logout"
                ],
                "responses": {
                    "204": {
                        "description": "No content"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        },
        "/auth/me": {
            "get": {
                "operationId": "auth.me",
                "tags": [
                    "Me"
                ],
                "responses": {
                    "200": {
                        "description": "`UserResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/UserResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        },
        "/reading-plans/{plan}/subscriptions": {
            "post": {
                "operationId": "reading-plans.subscriptions.store",
                "description": "Creates a new subscription for the authenticated user on the given\nreading plan, scheduled from the provided start date. Returns the\ncreated subscription with its generated day schedule.",
                "summary": "Start a reading plan subscription",
                "tags": [
                    "Reading Plan Subscriptions",
                    "StartReadingPlanSubscription"
                ],
                "parameters": [
                    {
                        "name": "plan",
                        "in": "path",
                        "required": true,
                        "description": "The plan slug",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/StartReadingPlanSubscriptionRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "`ReadingPlanSubscriptionResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ReadingPlanSubscriptionResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/reading-plan-subscriptions/{subscription}/days/{day}/complete": {
            "post": {
                "operationId": "reading-plan-subscriptions.days.complete",
                "description": "Marks the given day of the authenticated user's subscription as\ncompleted. The {day} parameter is scoped to the parent {subscription},\nso a day that does not belong to that subscription returns 404.",
                "summary": "Complete a subscription day",
                "tags": [
                    "Reading Plan Subscriptions",
                    "CompleteReadingPlanSubscriptionDay"
                ],
                "parameters": [
                    {
                        "name": "subscription",
                        "in": "path",
                        "required": true,
                        "description": "The subscription ID",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "day",
                        "in": "path",
                        "required": true,
                        "description": "The day ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`ReadingPlanSubscriptionDayResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ReadingPlanSubscriptionDayResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    },
                    "403": {
                        "$ref": "#/components/responses/AuthorizationException"
                    }
                }
            }
        },
        "/reading-plan-subscriptions/{subscription}/start-date": {
            "patch": {
                "operationId": "reading-plan-subscriptions.reschedule",
                "description": "Updates the start date of the authenticated user's reading plan\nsubscription and regenerates the day schedule from the new start date.",
                "summary": "Reschedule a subscription",
                "tags": [
                    "Reading Plan Subscriptions",
                    "RescheduleReadingPlanSubscription"
                ],
                "parameters": [
                    {
                        "name": "subscription",
                        "in": "path",
                        "required": true,
                        "description": "The subscription ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RescheduleReadingPlanSubscriptionRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "`ReadingPlanSubscriptionResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ReadingPlanSubscriptionResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    },
                    "403": {
                        "$ref": "#/components/responses/AuthorizationException"
                    }
                }
            }
        },
        "/reading-plan-subscriptions/{subscription}/finish": {
            "post": {
                "operationId": "reading-plan-subscriptions.finish",
                "description": "Marks the authenticated user's reading plan subscription as finished.\nRequires all days to be completed; otherwise the request is rejected.",
                "summary": "Finish a subscription",
                "tags": [
                    "Reading Plan Subscriptions",
                    "FinishReadingPlanSubscription"
                ],
                "parameters": [
                    {
                        "name": "subscription",
                        "in": "path",
                        "required": true,
                        "description": "The subscription ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`ReadingPlanSubscriptionResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ReadingPlanSubscriptionResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    },
                    "403": {
                        "$ref": "#/components/responses/AuthorizationException"
                    }
                }
            }
        },
        "/reading-plan-subscriptions/{subscription}/abandon": {
            "post": {
                "operationId": "reading-plan-subscriptions.abandon",
                "description": "Marks the authenticated user's reading plan subscription as abandoned.\nThe subscription is preserved for history but no longer counts as\nactive and cannot be resumed.",
                "summary": "Abandon a subscription",
                "tags": [
                    "Reading Plan Subscriptions",
                    "AbandonReadingPlanSubscription"
                ],
                "parameters": [
                    {
                        "name": "subscription",
                        "in": "path",
                        "required": true,
                        "description": "The subscription ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`ReadingPlanSubscriptionResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ReadingPlanSubscriptionResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    },
                    "403": {
                        "$ref": "#/components/responses/AuthorizationException"
                    }
                }
            }
        },
        "/reading-plans": {
            "get": {
                "operationId": "reading-plans.index",
                "description": "Returns a paginated list of published reading plans in the resolved\nlanguage. When the request is authenticated, each plan is enriched with\nthe current user's subscriptions and progress counts.",
                "summary": "List reading plans",
                "tags": [
                    "Reading Plans",
                    "ListReadingPlans"
                ],
                "parameters": [
                    {
                        "name": "language",
                        "in": "query",
                        "schema": {
                            "type": [
                                "string",
                                "null"
                            ]
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": [
                                "integer",
                                "null"
                            ],
                            "minimum": 1,
                            "maximum": 100
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated set of `ReadingPlanResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/ReadingPlanResource"
                                            }
                                        },
                                        "links": {
                                            "type": "object",
                                            "properties": {
                                                "first": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "last": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "prev": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "next": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "first",
                                                "last",
                                                "prev",
                                                "next"
                                            ]
                                        },
                                        "meta": {
                                            "type": "object",
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "minimum": 1
                                                },
                                                "from": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "minimum": 1
                                                },
                                                "last_page": {
                                                    "type": "integer",
                                                    "minimum": 1
                                                },
                                                "links": {
                                                    "type": "array",
                                                    "description": "Generated paginator links.",
                                                    "items": {
                                                        "type": "object",
                                                        "properties": {
                                                            "url": {
                                                                "type": [
                                                                    "string",
                                                                    "null"
                                                                ]
                                                            },
                                                            "label": {
                                                                "type": "string"
                                                            },
                                                            "active": {
                                                                "type": "boolean"
                                                            }
                                                        },
                                                        "required": [
                                                            "url",
                                                            "label",
                                                            "active"
                                                        ]
                                                    }
                                                },
                                                "path": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ],
                                                    "description": "Base path for paginator generated URLs."
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "description": "Number of items shown per page.",
                                                    "minimum": 0
                                                },
                                                "to": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "description": "Number of the last item in the slice.",
                                                    "minimum": 1
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "description": "Total number of items being paginated.",
                                                    "minimum": 0
                                                }
                                            },
                                            "required": [
                                                "current_page",
                                                "from",
                                                "last_page",
                                                "links",
                                                "path",
                                                "per_page",
                                                "to",
                                                "total"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data",
                                        "links",
                                        "meta"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/reading-plans/{plan}": {
            "get": {
                "operationId": "reading-plans.show",
                "description": "Returns a single reading plan resolved by slug, eagerly loading days and\ntheir fragments. When the request is authenticated, the user's own\nsubscriptions for this plan (with progress counts) are also embedded.",
                "summary": "Show a reading plan",
                "tags": [
                    "Reading Plans",
                    "ShowReadingPlan"
                ],
                "parameters": [
                    {
                        "name": "plan",
                        "in": "path",
                        "required": true,
                        "description": "The plan slug",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "language",
                        "in": "query",
                        "schema": {
                            "type": [
                                "string",
                                "null"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`ReadingPlanResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/ReadingPlanResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/auth/register": {
            "post": {
                "operationId": "auth.register",
                "tags": [
                    "Register"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterUserRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "user": {
                                                    "$ref": "#/components/schemas/UserResource"
                                                },
                                                "token": {
                                                    "type": "string"
                                                }
                                            },
                                            "required": [
                                                "user",
                                                "token"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "LoginUserRequest": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email"
                    },
                    "password": {
                        "type": "string"
                    }
                },
                "required": [
                    "email",
                    "password"
                ],
                "title": "LoginUserRequest"
            },
            "ReadingPlanDayFragmentResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "position": {
                        "type": "integer"
                    },
                    "type": {
                        "type": "string"
                    },
                    "content": {
                        "anyOf": [
                            {
                                "type": "null"
                            },
                            {
                                "type": "string"
                            },
                            {
                                "type": "array",
                                "items": {}
                            }
                        ]
                    }
                },
                "required": [
                    "id",
                    "position",
                    "type",
                    "content"
                ],
                "title": "ReadingPlanDayFragmentResource"
            },
            "ReadingPlanDayResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "position": {
                        "type": "integer"
                    },
                    "fragments": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ReadingPlanDayFragmentResource"
                        }
                    }
                },
                "required": [
                    "id",
                    "position",
                    "fragments"
                ],
                "title": "ReadingPlanDayResource"
            },
            "ReadingPlanResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "slug": {
                        "type": "string"
                    },
                    "name": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "description": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "image": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "thumbnail": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "published_at": {
                        "type": "string"
                    },
                    "days": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ReadingPlanDayResource"
                        }
                    },
                    "subscriptions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ReadingPlanSubscriptionResource"
                        }
                    }
                },
                "required": [
                    "id",
                    "slug",
                    "name",
                    "description",
                    "image",
                    "thumbnail",
                    "published_at"
                ],
                "title": "ReadingPlanResource"
            },
            "ReadingPlanSubscriptionDayResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "day_id": {
                        "type": "integer"
                    },
                    "position": {
                        "type": "integer"
                    },
                    "scheduled_date": {
                        "type": "string"
                    },
                    "completed_at": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "day_id",
                    "scheduled_date",
                    "completed_at"
                ],
                "title": "ReadingPlanSubscriptionDayResource"
            },
            "ReadingPlanSubscriptionResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "plan_id": {
                        "type": "integer"
                    },
                    "status": {
                        "type": "string"
                    },
                    "start_date": {
                        "type": "string"
                    },
                    "completed_at": {
                        "type": "string"
                    },
                    "progress": {
                        "type": "object",
                        "properties": {
                            "completed_days": {
                                "type": "integer"
                            },
                            "total_days": {
                                "type": "integer"
                            }
                        },
                        "required": [
                            "completed_days",
                            "total_days"
                        ]
                    },
                    "days": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ReadingPlanSubscriptionDayResource"
                        }
                    }
                },
                "required": [
                    "id",
                    "plan_id",
                    "status",
                    "start_date",
                    "completed_at",
                    "progress"
                ],
                "title": "ReadingPlanSubscriptionResource"
            },
            "RegisterUserRequest": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "maxLength": 255
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "maxLength": 255
                    },
                    "password": {
                        "type": "string",
                        "minLength": 8
                    },
                    "password_confirmation": {
                        "type": "string",
                        "minLength": 8
                    }
                },
                "required": [
                    "name",
                    "email",
                    "password",
                    "password_confirmation"
                ],
                "title": "RegisterUserRequest"
            },
            "RescheduleReadingPlanSubscriptionRequest": {
                "type": "object",
                "properties": {
                    "start_date": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "required": [
                    "start_date"
                ],
                "title": "RescheduleReadingPlanSubscriptionRequest"
            },
            "StartReadingPlanSubscriptionRequest": {
                "type": "object",
                "properties": {
                    "start_date": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date-time"
                    }
                },
                "title": "StartReadingPlanSubscriptionRequest"
            },
            "UserResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "name",
                    "email",
                    "created_at"
                ],
                "title": "UserResource"
            }
        },
        "responses": {
            "ValidationException": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Errors overview."
                                },
                                "errors": {
                                    "type": "object",
                                    "description": "A detailed description of each field that failed validation.",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "required": [
                                "message",
                                "errors"
                            ]
                        }
                    }
                }
            },
            "AuthenticationException": {
                "description": "Unauthenticated",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Error overview."
                                }
                            },
                            "required": [
                                "message"
                            ]
                        }
                    }
