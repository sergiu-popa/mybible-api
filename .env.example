APP_NAME="MyBible API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.mybible.local

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Horizon dashboard mounts on the API host at `/horizon` (super-admin gated).
# `null` keeps it on the API host; do not move it to a public sub-domain.
HORIZON_DOMAIN=null
HORIZON_PATH=horizon

CACHE_STORE=redis
CACHE_PREFIX=mybible-api
# Stale-while-revalidate grace window for Cache::flexible() (seconds).
# CACHE_FLEXIBLE_GRACE=60

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_USERNAME=
REDIS_PASSWORD=null
REDIS_PORT=6379
# tcp for the docker-local stack; tls for the managed Valkey cluster.
REDIS_SCHEME=tcp
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Docker
WWWUSER=1000
WWWGROUP=1000
XDEBUG_MODE=off

# Auth — Sanctum
SANCTUM_TOKEN_EXPIRATION=20160

# Auth — API keys (rotation = change value + redeploy)
API_KEY_MOBILE=
API_KEY_ADMIN=
API_KEY_FRONTEND=

# Mobile app version metadata (exposed via GET /api/v1/mobile/version)
MOBILE_IOS_MIN=3.0.0
MOBILE_IOS_LATEST=3.4.1
MOBILE_IOS_URL=
MOBILE_IOS_FORCE=3.0.0

MOBILE_ANDROID_MIN=3.0.0
MOBILE_ANDROID_LATEST=3.4.1
MOBILE_ANDROID_URL=
MOBILE_ANDROID_FORCE=3.0.0

# Bootstrap endpoint — app-level cache TTL in seconds (default 300)
BOOTSTRAP_CACHE_TTL=300

# Sync delta endpoint — max rows per type per call (default 5000)
SYNC_PER_TYPE_CAP=5000

# Health — readiness probe is VPC-only; set to LB CIDR in production.
# In local Docker dev override to: 127.0.0.1/32,172.16.0.0/12
INTERNAL_OPS_CIDR=10.114.0.0/20

# Rate limiting — comma-separated trusted proxy CIDRs, or '*' for all.
# Must be tightened to the LB CIDR in production.
TRUSTED_PROXIES=*

# Anthropic Claude API — required for the AI domain (AddReferences, etc.).
# Leave blank in local dev unless you intend to actually hit the API.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_REQUEST_TIMEOUT_SECONDS=60
AI_RETRY_MAX_ATTEMPTS=3
AI_DEFAULT_BIBLE_VERSION_FALLBACK=VDC
